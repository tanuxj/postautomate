# xAI (Grok) API key — https://console.x.ai
XAI_API_KEY=

# X (Twitter) API v2 credentials — https://developer.x.com/en/portal/dashboard
# App must have Read+Write permissions, and these must be OAuth 1.0a
# *user context* tokens (not just the App-only bearer token).
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
